# Vertex AI (GCP)
GOOGLE_CLOUD_PROJECT=seu-projeto-gcp
GOOGLE_CLOUD_LOCATION=us-central1
VERTEXAI_MODEL=gemini-2.5-flash
VERTEXAI_FALLBACK_MODEL=gemini-2.5-flash-lite
VERTEXAI_RPM=1000
VERTEXAI_RPD=100000
# Autenticacao: execute `gcloud auth application-default login`
# ou defina GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_legis

EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBED_BATCH=32
EMBED_DEVICE=cuda

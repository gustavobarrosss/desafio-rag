# === Vertex AI (GCP) ===
# Projeto INFRA (VM, GCS, Artifact Registry, Vertex Custom Jobs)
GCP_INFRA_PROJECT=desafio-rag
# Projeto LLM (Vertex AI Gemini para vision OCR + QA)
GCP_LLM_PROJECT=bionic-medley-489719-t5

# GOOGLE_CLOUD_PROJECT é usado como fallback pelo SDK e pelo client Vertex
GOOGLE_CLOUD_PROJECT=${GCP_LLM_PROJECT}
GOOGLE_CLOUD_LOCATION=us-central1

VERTEXAI_MODEL=gemini-2.5-flash
VERTEXAI_FALLBACK_MODEL=gemini-2.5-flash-lite
VERTEXAI_RPM=1000
VERTEXAI_RPD=100000

# Autenticação:
# - Local dev: `gcloud auth application-default login`
# - VM/container: monte a chave da SA LLM vinda do Secret Manager e aponte:
#   VERTEX_LLM_CREDENTIALS_PATH=/var/secrets/vertex-llm-sa.json
VERTEX_LLM_CREDENTIALS_PATH=

# === Storage / Paths ===
# Local dev: defaults apontam para ./data dentro do repo.
# Na VM (prod): DATA_DIR=/mnt/gcs/aneel-rag-data, STATE_DB_PATH=/var/lib/aneel/state.sqlite
# DATA_DIR=/mnt/gcs/aneel-rag-data
# STATE_DB_PATH=/var/lib/aneel/state.sqlite

# Bucket GCS onde ficam PDFs / parsed / chunks / metadata
GCS_BUCKET=aneel-rag-data-desafio-rag
# Prefixo dentro do bucket onde os metadados JSON são baixados no init
GCS_METADATA_PREFIX=metadata

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_legis

# === Embedding ===
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBED_BATCH=32
EMBED_DEVICE=cuda
